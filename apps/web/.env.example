NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Bot-signup defenses ──────────────────────────────────────────────────────
# Cloudflare Turnstile (free CAPTCHA). Both vars REQUIRED for the signup form
# to actually run a check. If TURNSTILE_SECRET_KEY is missing, the verify
# route fails-closed (returns 403). If NEXT_PUBLIC_TURNSTILE_SITE_KEY is
# missing, the widget hides gracefully and signup falls back to the existing
# rate-limit-only path. Get keys from https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Operator kill-switch for the datacenter-CIDR block in middleware.ts. Set to
# "1" if support reports false positives from VPN users on AWS/Azure/GCP.
# Default (unset) = block enabled.
DISABLE_DATACENTER_CIDR_BLOCK=
