NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Feature flags — read by src/config/features.ts.
# Set both to flip back: PAID_TIERS_ENABLED=true, BETA_MODE=false.
NEXT_PUBLIC_PAID_TIERS_ENABLED=false
NEXT_PUBLIC_BETA_MODE=true
# Peer RolePlay (live 2-player video) is the most expensive per-session feature
# (TURN bandwidth + dual Whisper STT + Anthropic examiner). Off by default
# during beta. Flip to true once monetisation is back and we can absorb cost.
NEXT_PUBLIC_PEER_ROLEPLAY_IN_BETA=false
