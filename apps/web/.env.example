NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cloud TTS — the AI patient voice (web + mobile) via ElevenLabs.
# /api/tts streams MP3 audio for the patient's reply. If unset, the route
# returns 503 and the client silently falls back to the old browser /
# expo-speech native voice — handy as a kill-switch.
ELEVENLABS_API_KEY=your_elevenlabs_api_key   # sk_... from elevenlabs.io
# Optional voice overrides. Defaults are British premade voices (closest
# premade accent to en-AU). Swap in any voice ID from your ElevenLabs voice
# library — including a cloned/native Australian voice.
ELEVENLABS_VOICE_FEMALE=                       # default: Alice (British female)
ELEVENLABS_VOICE_MALE=                         # default: Daniel (British male)

# Feature flags — read by src/config/features.ts.
# Set both to flip back: PAID_TIERS_ENABLED=true, BETA_MODE=false.
NEXT_PUBLIC_PAID_TIERS_ENABLED=false
NEXT_PUBLIC_BETA_MODE=true
# Peer RolePlay (live 2-player video) is the most expensive per-session feature
# (TURN bandwidth + dual Whisper STT + Anthropic examiner). Off by default
# during beta. Flip to true once monetisation is back and we can absorb cost.
NEXT_PUBLIC_PEER_ROLEPLAY_IN_BETA=false
