{
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm build --filter=@mostly-medicine/web",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/billing-resync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/health-keepalive",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/brain-teaser",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/publish-linkedin",
      "schedule": "0 0 * * *"
    }
  ]
}
