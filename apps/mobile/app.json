{
  "expo": {
    "name": "mostlymedicine",
    "slug": "mostly-medicine",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mostlymedicine",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0369a1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mostlymedicine.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0369a1"
      },
      "package": "com.mostlymedicine.app",
      "newArchEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "920b217e-54c9-4a29-b24b-1b0cc58cfbb2"
      }
    },
    "owner": "kamboj.chetan18"
  }
}
